# MediScan AI - Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Generate a strong secret key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-hex-string

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (default: SQLite for local dev, use PostgreSQL for production)
DATABASE_URL=sqlite:///./mediscan.db
# DATABASE_URL=postgresql://user:password@localhost:5432/mediscan

# Path to trained model checkpoint
MODEL_PATH=./model/mediscan_v5.pth

# Directory to store uploaded X-ray images
UPLOAD_DIR=./uploads

# CORS origins allowed to call the API (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
